# ===== 时区配置 =====
TZ=Asia/Shanghai

# ===== 数据库配置 =====
DB_USER=e9salary
DB_PASSWORD=e9salary_change_me
DB_NAME=e9_salary
# 数据库容器内部端口（固定 5432，一般不用改）
DB_INTERNAL_PORT=5432
# Docker 环境下数据库服务名（docker-compose 中服务名）
DB_CONTAINER_HOST=db
# Docker 映射到宿主机的端口
DB_DOCKER_PORT=5433
# 本地开发端口（非 Docker）
DB_LOCAL_PORT=5432

# 本地开发用 DATABASE_URL（Docker 启动时 docker-compose.yml 会覆盖此值）
DATABASE_URL=postgresql://e9salary:e9salary_change_me@127.0.0.1:5432/e9_salary

# ===== 后端配置 =====
SECRET_KEY=please-change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
# 本地开发端口（非 Docker，项目规则规定 8010）
BACKEND_PORT=8010
# Docker 环境后端端口（容器内部和映射到宿主机统一用 8001）
BACKEND_DOCKER_PORT=8001
# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== 前端配置 =====
# 本地开发端口（非 Docker，项目规则规定 5180）
FRONTEND_PORT=5180
# Docker 映射到宿主机端口
FRONTEND_DOCKER_PORT=8080
# 容器内部端口（Nginx 默认 80）
FRONTEND_INTERNAL_PORT=80

# ===== CORS 跨域白名单 =====
# 本地开发
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180
# Docker 环境
DOCKER_CORS_ORIGINS=http://localhost,http://localhost:8080,http://127.0.0.1:8080

# ===== 阿里云百炼 AI 配置 =====
LLM_API_KEY=your-dashscope-api-key
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ===== 钉钉内部应用配置 =====
DINGTALK_CLIENT_ID=your-dingtalk-client-id
DINGTALK_CLIENT_SECRET=your-dingtalk-client-secret
DINGTALK_AGENT_ID=your-dingtalk-agent-id
DINGTALK_ROBOT_CODE=your-dingtalk-robot-code

# ===== 目录配置（一般不用改，Docker 通过 environment 覆盖） =====
# 本地开发默认在项目根目录下
# DATA_DIR=./data/app
# TEMP_DIR=./temp
# BACKUP_DIR=./backups
