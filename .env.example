# ===== 数据库配置（Docker PostgreSQL） =====
DB_USER=e9salary
DB_PASSWORD=请修改为你的密码
DB_NAME=e9_salary
DB_EXTERNAL_PORT=5434

# 本地开发用 DATABASE_URL（Docker 启动时 docker-compose.yml 会覆盖此值）
DATABASE_URL=postgresql://e9salary:请修改密码@localhost:5434/e9_salary

# ===== 后端配置 =====
BACKEND_SECRET_KEY=请生成一个随机密钥
BACKEND_PORT=8010
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ===== 前端配置 =====
FRONTEND_PORT=5180

# ===== CORS 跨域白名单 =====
CORS_ORIGINS=http://localhost,http://localhost:5180,http://localhost:80

# ===== 钉钉内部应用配置 =====
DINGTALK_CLIENT_ID=你的钉钉应用ClientID
DINGTALK_CLIENT_SECRET=你的钉钉应用ClientSecret
DINGTALK_AGENT_ID=你的钉钉应用AgentId
DINGTALK_ROBOT_CODE=你的钉钉应用RobotCode