# ===== 数据库配置（Docker PostgreSQL） =====
DB_USER=e9salary
DB_PASSWORD=e9salary_change_me
DB_NAME=e9_salary
DB_EXTERNAL_PORT=5433

# 本地开发用 DATABASE_URL（Docker 启动时 docker-compose.yml 会覆盖此值）
DATABASE_URL=postgresql://e9salary:e9salary_change_me@localhost:5432/e9_salary

# ===== 后端配置 =====
SECRET_KEY=please-change-this-to-a-random-secret-key-in-production
BACKEND_PORT=8001
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== 前端配置 =====
FRONTEND_PORT=8080

# ===== CORS 跨域白名单 =====
CORS_ORIGINS=http://localhost,http://localhost:8080,http://localhost:80

# ===== 阿里云百炼 AI 配置 =====
LLM_API_KEY=your-dashscope-api-key
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_MODEL=qwen-plus

# ===== 钉钉内部应用配置 =====
DINGTALK_CLIENT_ID=your-dingtalk-client-id
DINGTALK_CLIENT_SECRET=your-dingtalk-client-secret
DINGTALK_AGENT_ID=your-dingtalk-agent-id
DINGTALK_ROBOT_CODE=your-dingtalk-robot-code
DINGTALK_SYNC_DEPT_NAMES=
